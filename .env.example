# Oracle Cloud Infrastructure (OCI) credentials and deployment settings
# Copy this file to .env and fill in your actual values.

OCI_USER_OCID=
OCI_TENANCY_OCID=
OCI_REGION=
OCI_FINGERPRINT=
OCI_PRIVATE_KEY=
OCI_SUBNET_OCID=o
# https://docs.oracle.com/en-us/iaas/images/ubuntu-2404/canonical-ubuntu-24-04-aarch64-2026-02-28-0.htm
OCI_IMAGE_OCID=
OCI_SSH_PUBLIC_KEY=

# Slack notification webhook URL
SLACK_WEBHOOK_URL=

# Optional settings
OCI_COMPARTMENT_OCID=
OCI_AD=
OCI_SHAPE=
OCI_OS=Ubuntu-

# Notes:
# - OCI_PRIVATE_KEY should contain the full PEM-formatted private key text.
# - OCI_SSH_PUBLIC_KEY should contain the full public key text, e.g. the contents of ~/.ssh/id_rsa.pub.
# - OCI_AD and OCI_SHAPE are provided as defaults for Oracle Free ARM instance creation.
